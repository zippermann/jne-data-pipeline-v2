# ============================================================
# JNE Data Pipeline v2 — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
# ============================================================

# ------------------------------------------------------------
# Oracle
# ORACLE_DSN is the EZConnect string used by extract_bronze.py.
# Format: host:port/service_name
# ------------------------------------------------------------
ORACLE_DSN=oracle-host:1521/ORCL
ORACLE_HOST=oracle-host
ORACLE_PORT=1521
ORACLE_SERVICE=ORCL
ORACLE_SID=
ORACLE_USER=HOA
ORACLE_PASSWORD=changeme
ORACLE_SCHEMA=JNE
ORACLE_PARALLEL_DEGREE=2

# ------------------------------------------------------------
# MinIO (bronze layer storage)
# MINIO_ENDPOINT must be reachable from inside Docker containers
# (use http://minio:9000, not localhost, for inter-service calls).
# ------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jne-bronze

# MinIO web console ports (host-side)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------
# Bronze extract tuning
# ------------------------------------------------------------
BRONZE_WORKERS=4
BRONZE_CHUNKSIZE=100000

# ------------------------------------------------------------
# PostgreSQL (silver layer + Airflow metadata)
# ------------------------------------------------------------
POSTGRES_USER=jne_user
POSTGRES_PASSWORD=jne_secure_password_2024
POSTGRES_DB=jne_dashboard
POSTGRES_PORT=5433

# ------------------------------------------------------------
# Airflow
# ------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_PORT=8081

# ------------------------------------------------------------
# pgAdmin
# ------------------------------------------------------------
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5051

