# JNE Data Pipeline v2 — Environment Configuration
# Copy this file to .env and update with your values.
# .env is gitignored and must never be committed.
#
# Port conflicts with v1? The defaults below are already offset.
# Everything adapts automatically from these values.

# ============================================================
# PORTS (v2 defaults are offset +1 from v1 to avoid conflicts)
# ============================================================
POSTGRES_PORT=5433
AIRFLOW_PORT=8081
PGADMIN_PORT=5051
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# PostgreSQL (silver layer + Airflow metadata)
# ============================================================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ============================================================
# Oracle (source database)
# ============================================================
# Use ORACLE_SID for SID-based connections, ORACLE_SERVICE for service name.
# If both are set, SID takes precedence.
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SID=
ORACLE_SERVICE=
ORACLE_USER=HOA
ORACLE_PASSWORD=
ORACLE_SCHEMA=JNE
ORACLE_PARALLEL_DEGREE=2

# Rolling extraction window (months)
EXTRACTION_WINDOW_MONTHS=3

# Optional: override window in days (non-empty overrides EXTRACTION_WINDOW_MONTHS).
# Useful for small test runs, e.g. EXTRACTION_WINDOW_DAYS=3
# EXTRACTION_WINDOW_DAYS=

# Incremental overlap — re-queries this many extra days on incremental runs
# to catch late-arriving records.
INCREMENTAL_OVERLAP_DAYS=1

# ============================================================
# MinIO (bronze layer — S3-compatible storage)
# MINIO_ENDPOINT must use the Docker service name (not localhost)
# for inter-container calls: http://minio:9000
# ============================================================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jne-bronze
MINIO_SECURE=false

# ============================================================
# Bronze extract tuning
# ============================================================
BRONZE_WORKERS=4
BRONZE_CHUNKSIZE=100000

# ============================================================
# Airflow admin user (created on first startup)
# ============================================================
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=

# ============================================================
# pgAdmin
# ============================================================
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# ============================================================
# Audit retention
# ============================================================
AUDIT_RETENTION_MONTHS=6
