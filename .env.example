# JNE Data Pipeline v2 — Environment Configuration
# Copy this file to .env and update with your values.
# .env is gitignored and must never be committed.
#
# ============================================================
# PORTS
# ============================================================
AIRFLOW_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# Oracle (source database)
# ============================================================
# Use ORACLE_SID for SID-based connections, ORACLE_SERVICE for service name.
# If both are set, SID takes precedence.
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SID=
ORACLE_SERVICE=
ORACLE_USER=HOA
ORACLE_PASSWORD=
ORACLE_SCHEMA=JNE

# ============================================================
# MinIO (bronze data lake)
# ============================================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=jne-bronze

# ============================================================
# Bronze extract tuning
# ============================================================
BRONZE_WORKERS=4

# ============================================================
# Airflow admin user (created on first startup)
# ============================================================
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=
